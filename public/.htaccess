<IfModule mod_headers.c>
	Header always set Content-Security-Policy "frame-ancestors 'none'"
	Header always set X-Content-Type-Options "nosniff"
	Header always set X-Frame-Options "DENY"
	Header always set Referrer-Policy "strict-origin-when-cross-origin"
	Header always set Permissions-Policy "camera=(), geolocation=(), microphone=(), payment=(), usb=()"

	<FilesMatch "-[A-Za-z0-9_-]{8}\.(?:css|js)$">
		Header always set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>

	<FilesMatch "\.(?:avif|gif|ico|jpe?g|mp4|pdf|png|svg|vtt|webp)$">
		Header always set Cache-Control "public, max-age=604800"
	</FilesMatch>

	<FilesMatch "\.html$">
		Header always set Cache-Control "no-cache, must-revalidate"
	</FilesMatch>
</IfModule>
